# ============================================================
# Maable — Environment Variables
# Copy to .env.local and fill in real values. NEVER commit .env files.
# ============================================================

# ─── Supabase (shared across web + mobile) ────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Expo / React Native versions of the same vars
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ─── Web app ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase service role (server-side only, NEVER expose to client) ─────────
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ─── OAuth — Canvas LMS ───────────────────────────────────────────────────────
# Register at: your-institution.instructure.com/profile/developer_keys
CANVAS_CLIENT_ID=
CANVAS_CLIENT_SECRET=

# ─── OAuth — ManageBac ────────────────────────────────────────────────────────
# Register at: https://managebac.com/api/oauth
MANAGEBAC_CLIENT_ID=
MANAGEBAC_CLIENT_SECRET=

# ─── OAuth — LinkedIn ─────────────────────────────────────────────────────────
# Register at: https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ─── Payments — RevenueCat ────────────────────────────────────────────────────
# https://app.revenuecat.com
REVENUECAT_WEBHOOK_SECRET=
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_XXXX

# ─── Token encryption ─────────────────────────────────────────────────────────
# 32-byte hex key for AES-256 token encryption in Edge Functions
TOKEN_ENCRYPTION_KEY=GENERATE_WITH: openssl rand -hex 32

# ─── App URL (Edge Functions) ─────────────────────────────────────────────────
APP_URL=http://localhost:3000
