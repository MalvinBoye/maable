{
  "expo": {
    "name": "Maable",
    "slug": "maable",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "maable",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#09090b"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.maable.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Maable uses the camera for profile photos.",
        "NSPhotoLibraryUsageDescription": "Maable accesses photos for profile and note attachments.",
        "NSMicrophoneUsageDescription": "Not used by this app."
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-av",
        { "microphonePermission": false }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    }
  }
}
